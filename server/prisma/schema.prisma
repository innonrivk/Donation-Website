generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DONOR
  ADMIN
}

enum TransactionStatus {
  SUCCEEDED
  FAILED
  REFUNDED
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}

enum PiggyBankType {
  DONOR_SEED
  SHAREHOLDER_CAMPAIGN
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  password           String?
  googleId           String?             @unique @map("google_id")
  firstName          String              @map("first_name")
  lastName           String              @map("last_name")
  country            String              @default("")
  role               UserRole            @default(DONOR)
  stripeCustomerId   String?             @unique @map("stripe_customer_id")
  monthlyAmount      Int                 @default(0) @map("monthly_amount")
  isActive           Boolean             @default(true) @map("is_active")
  scheduledAmount    Int?                @map("scheduled_amount")
  scheduledAmountEffectiveDate DateTime? @map("scheduled_amount_effective_date")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  transactions       Transaction[]
  votes              Vote[]
  claimedMilestones  ClaimedMilestone[]

  @@map("users")
}

model Transaction {
  id                     String            @id @default(uuid())
  userId                 String            @map("user_id")
  stripePaymentIntentId  String?           @unique @map("stripe_payment_intent_id")
  stripeInvoiceId        String?           @unique @map("stripe_invoice_id")
  amount                 Int               // in cents
  status                 TransactionStatus @default(SUCCEEDED)
  createdAt              DateTime          @default(now()) @map("created_at")
  user                   User              @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("transactions")
}

model Tier {
  id        Int     @id @default(autoincrement())
  tierLevel Int     @map("tier_level")
  name      String
  minAmount Int     @map("min_amount") // in dollars
  maxAmount Int?    @map("max_amount") // null = unlimited
  perks     Json    @default("[]")

  @@map("tiers")
}

model DonationBox {
  id             Int     @id @default(autoincrement())
  title          String
  amount         Int     @default(0) // monthly amount in dollars
  tierDetails    String  @default("") @map("tier_details")
  buttonText     String  @default("Donate") @map("button_text")
  isCustomAmount Boolean @default(false) @map("is_custom_amount")
  isRecurring    Boolean @default(true) @map("is_recurring")
  isActive       Boolean @default(true) @map("is_active")
  displayOrder   Int     @default(0) @map("display_order")

  @@map("donation_boxes")
}

model WebsiteContent {
  id        Int      @id @default(autoincrement())
  head      String   @default("")
  subtitle  String   @default("")
  body      String   @default("")
  version   Int      @default(1)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("website_content")
}

model ProjectDetail {
  id           Int           @id @default(autoincrement())
  projectName  String        @map("project_name")
  details      String        @default("")
  status       ProjectStatus @default(ACTIVE)
  imageUrl     String?       @map("image_url")
  fundingGoal  Int           @default(0) @map("funding_goal")  // in cents
  fundedAmount Int           @default(0) @map("funded_amount") // in cents
  piggyBanks   PiggyBank[]
  votes        Vote[]

  @@map("projects_detail")
}

model PiggyBank {
  id          Int           @id @default(autoincrement())
  bankType    PiggyBankType @map("bank_type")
  projectId   Int?          @map("project_id")
  balance     Int           @default(0) // in cents
  periodMonth DateTime      @map("period_month")
  project     ProjectDetail? @relation(fields: [projectId], references: [id])
  votes       Vote[]

  @@map("piggy_banks")
}

model Vote {
  id          Int           @id @default(autoincrement())
  userId      String        @map("user_id")
  projectId   Int           @map("project_id")
  piggyBankId Int           @map("piggy_bank_id")
  seedCount   Int           @default(1) @map("seed_count")
  createdAt   DateTime      @default(now()) @map("created_at")
  user        User          @relation(fields: [userId], references: [id])
  project     ProjectDetail @relation(fields: [projectId], references: [id])
  piggyBank   PiggyBank     @relation(fields: [piggyBankId], references: [id])

  @@map("votes")
}

model DonationMilestone {
  id           Int                @id @default(autoincrement())
  amountUsd    Int                @map("amount_usd")
  label        String
  description  String
  isRepeatable Boolean            @default(false) @map("is_repeatable")
  displayOrder Int                @default(0) @map("display_order")
  claimedBy    ClaimedMilestone[]

  @@map("donation_milestones")
}

model ClaimedMilestone {
  id          Int               @id @default(autoincrement())
  userId      String            @map("user_id")
  milestoneId Int               @map("milestone_id")
  claimedAt   DateTime          @default(now()) @map("claimed_at")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone   DonationMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([userId, milestoneId])
  @@map("claimed_milestones")
}

model UserOtp {
  id        String   @id @default(uuid())
  email     String
  otp       String   // Stored as bcrypt hash
  purpose   String   // 'REGISTRATION' | 'PASSWORD_CHANGE' | 'EMAIL_CHANGE'
  newEmail  String?  @map("new_email")
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_otps")
}

